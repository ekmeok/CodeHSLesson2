//Brush away row 1
while (frontIsClear()) {
    move();
    if (colorIs(Color.purple)) {
        paint(Color.yellow);
    } else if (colorIs(Color.green)) {
        paint(Color.yellow);
    } else {
        paint(Color.gray);
    }
}


