function start() {
    while (frontIsClear()) {
        checkForSnake();
        move();
    }
    checkForSnake();
}

function checkForSnake() {
    if (colorIs(Color.black)) {
        jumpUpAndDown();
        paint(Color.orange);
    }
}

function jumpUpAndDown() {
    turnLeft();
    move();
    turnAround();
    move();
    turnLeft(); 
}
